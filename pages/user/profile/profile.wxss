/* 页面基础样式 */
.page-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  /* 减少页面整体顶部内边距 */
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  padding-top: calc(constant(safe-area-inset-top) + 20rpx);
  box-sizing: border-box;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  /* 适配顶部安全区 */
  padding-top: calc(15rpx + env(safe-area-inset-top) + 40rpx);
  padding-top: calc(15rpx + constant(safe-area-inset-top) + 40rpx);
  min-height: 100rpx;
  height: auto;
  box-sizing: border-box;
}

.nav-back {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 500;
  flex: 1;
  text-align: center;
}

/* 模块样式 */
.section {
  background-color: #fff;
  margin-top: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

/* 信息条目 */
.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  width: 120rpx;
}

.info-content {
  flex: 1;
  text-align: right;
}

.avatar-img {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.info-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #333;
}

.info-content-static {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #333;
}

/* 保存按钮 */
.save-btn {
  margin: 40rpx 20rpx;
  padding: 15rpx 0;
  background-color: #2F8FC7;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
}

/* 按钮样式重置 */
.avatar-btn {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
}

.avatar-btn::after {
  border: none;
}

.save-btn::after {
  border: none;
}

/* 按钮组样式 */
.button-group {
  display: flex;
  flex-direction: column;
  margin: 40rpx 20rpx;
  gap: 20rpx;
}

/* 退出登录按钮 */
.logout-btn {
  padding: 15rpx 0;
  background-color: #999;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
}

.logout-btn::after {
  border: none;
}