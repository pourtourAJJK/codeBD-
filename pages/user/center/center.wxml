<!-- 我的页面 -->
<!-- 加载动画组件 -->
<loading visible="{{isLoading}}"></loading>
<view class="user-page">
  <!-- 顶部用户横幅（含背景图） -->
  <view class="user-banner">
    <!-- 背景图 -->
    <image class="banner-bg" src="{{userInfo.bannerBg || ''}}" mode="widthFix"></image>
    <!-- 新增叠加图片 -->
    <image class="overlay-image" src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/5313351.png" mode="widthFix"></image>
    <!-- 用户信息（点击跳转个人信息页） -->
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || ''}}" mode="widthFix"></image>
      <!-- 事件绑定：点击该区域跳转 -->
      <view class="user-detail" bindtap="toPersonalInfo">
        <text class="user-name">{{userInfo.nickName || '暂未登录'}}</text>
        <text class="user-phone">{{userInfo.nickName ? '' : '请点击头像进行登录'}}</text>
      </view>

    </view>
  </view>

  <!-- 我的订单模块 -->
  <view class="order-module" bindtap="toAllOrders">
    <view class="module-header">
      <text class="module-title">我的订单</text>
      <text class="view-all" bindtap="toAllOrders">查看全部</text>
    </view>
    <!-- 订单状态标签 -->
    <view class="order-grid">
      <view 
        class="order-item" 
        bindtap="toOrder"
        data-type="all"
      >
        <view class="order-icon">
          <image src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/全部订单BLUE.png" mode="widthFix"></image>
        </view>
        <text class="order-text">全部订单</text>
      </view>
      <view 
        class="order-item" 
        bindtap="toOrder"
        data-type="unpaid"
      >
        <view class="order-icon">
          <image src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/待配送blue.png" mode="widthFix"></image>
        </view>
        <text class="order-text">待支付</text>
      </view>
      <view 
        class="order-item" 
        bindtap="toOrder"
        data-type="pending_delivery"
      >
        <view class="order-icon">
          <image src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/待配送blue.png" mode="widthFix"></image>
        </view>
        <text class="order-text">待配送</text>
      </view>
      <view 
        class="order-item" 
        bindtap="toOrder"
        data-type="delivering"
      >
        <view class="order-icon">
          <image src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/_订单 处理中blue.png" mode="widthFix"></image>
        </view>
        <text class="order-text">配送中</text>
      </view>
      <view 
        class="order-item" 
        bindtap="toOrder"
        data-type="completed"
      >
        <view class="order-icon">
          <image src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/_订单 已成功BLUE.png" mode="widthFix"></image>
        </view>
        <text class="order-text">已完成</text>
      </view>
      <view 
        class="order-item" 
        bindtap="toOrder"
        data-type="after_sales"
      >
        <view class="order-icon">
          <image src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/售后BLUE.png" mode="widthFix"></image>
        </view>
        <text class="order-text">退单/售后</text>
      </view>
    </view>
  </view>

 
  <!-- 我的服务模块 -->
    <view class="service-module">
      <text class="service-title">我的服务</text>
      <view class="service-grid">
        <view class="service-item" bindtap="toService" data-type="address">
          <image class="service-icon" src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/地址bule.png"></image>
          <text class="service-text">地址管理</text>
        </view>
        <view class="service-item" bindtap="toService" data-type="about">
          <image class="service-icon" src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/设置blue.png"></image>
          <text class="service-text">设置</text>
        </view>
      </view>
    </view>
    
    <!-- 安全区域占位符 -->
    <view class="safe-area-bottom"></view>
</view>