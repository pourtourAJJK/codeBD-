.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  height: 44px;
  background-color: #fff;
  border-bottom: 1px solid #e0e0e0;
  padding: 0 15px;
}

.back {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 18px;
  margin-right: 5px;
}

.back-text {
  font-size: 14px;
  color: #333;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.content {
  padding: 15px;
}

.section {
  background-color: #fff;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 15px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.info-item {
  display: flex;
  margin-bottom: 10px;
  align-items: center;
}

.info-label {
  font-size: 14px;
  color: #666;
  width: 80px;
}

.info-value {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.amount {
  color: #f44336;
  font-weight: 600;
}

.status-box {
  background-color: #f9f9f9;
  border-radius: 6px;
  padding: 12px;
}

.status-item {
  display: flex;
  margin-bottom: 8px;
  align-items: center;
}

.status-label {
  font-size: 14px;
  color: #666;
  width: 80px;
}

.status-value {
  flex: 1;
  font-size: 14px;
  font-weight: 500;
}

.note-box {
  background-color: #fff3f3;
  border: 1px solid #ffdddd;
  border-radius: 6px;
  padding: 12px;
}

.note-content {
  font-size: 14px;
  color: #f44336;
  line-height: 1.5;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200px;
  font-size: 14px;
  color: #999;
}

.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200px;
  font-size: 14px;
  color: #999;
}