<view class="container">
  <view class="header">
    <view class="back" bindtap="goBack">
      <text class="back-icon">←</text>
      <text class="back-text">返回</text>
    </view>
    <view class="title">退款详情</view>
  </view>

  <view class="content" wx:if="{{ !loading && refundInfo }}">
    <!-- 基本信息 -->
    <view class="section">
      <view class="section-title">基本信息</view>
      <view class="info-item">
        <text class="info-label">退款单号：</text>
        <text class="info-value">{{ refundInfo.out_refund_no }}</text>
      </view>
      <view class="info-item">
        <text class="info-label">申请时间：</text>
        <text class="info-value">{{ refundInfo.apply_time ? (refundInfo.apply_time.toLocaleString() || refundInfo.apply_time) : '-' }}</text>
      </view>
      <view class="info-item">
        <text class="info-label">退款金额：</text>
        <text class="info-value amount">¥{{ (refundInfo.refund_amount / 100).toFixed(2) }}</text>
      </view>
      <view class="info-item">
        <text class="info-label">订单金额：</text>
        <text class="info-value">¥{{ (refundInfo.total_amount / 100).toFixed(2) }}</text>
      </view>
      <view class="info-item">
        <text class="info-label">退款原因：</text>
        <text class="info-value">{{ refundInfo.reason }}</text>
      </view>
    </view>

    <!-- 状态信息 -->
    <view class="section">
      <view class="section-title">状态信息</view>
      <view class="status-box">
        <view class="status-item">
          <text class="status-label">审核状态：</text>
          <text class="status-value" style="color: {{ refundInfo.audit_status === '待审核' ? '#ff9800' : refundInfo.audit_status === '通过' ? '#4caf50' : '#f44336' }}">{{ refundInfo.audit_status }}</text>
        </view>
        <view class="status-item">
          <text class="status-label">退款状态：</text>
          <text class="status-value" style="color: {{ refundInfo.refund_status === '待审核' ? '#ff9800' : refundInfo.refund_status === '退款中' ? '#2196f3' : refundInfo.refund_status === '退款成功' ? '#4caf50' : '#f44336' }}">{{ refundInfo.refund_status }}</text>
        </view>
        <view class="status-item">
          <text class="status-label">退款结果：</text>
          <text class="status-value">{{ refundInfo.refund_result_status }}</text>
        </view>
        <view class="status-item">
          <text class="status-label">订单状态：</text>
          <text class="status-value">{{ statusMap[refundInfo.statusmax] || '未知状态' }}</text>
        </view>
      </view>
    </view>

    <!-- 拒绝原因 -->
    <view class="section" wx:if="{{ refundInfo.audit_status === '拒绝' && refundInfo.audit_note }}">
      <view class="section-title">拒绝原因</view>
      <view class="note-box">
        <text class="note-content">{{ refundInfo.audit_note }}</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{ loading }}">
    <text>加载中...</text>
  </view>

  <!-- 无数据 -->
  <view class="empty" wx:if="{{ !loading && !refundInfo }}">
    <text>未找到退款记录</text>
  </view>
</view>