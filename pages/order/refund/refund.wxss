.refund-page { min-height: 100vh; background: #f5f5f5; padding: 12rpx 0 140rpx; }
.header { text-align: center; font-size: 34rpx; font-weight: 600; color: #111; margin-bottom: 12rpx; }
.item-card { background: #fff; margin: 0 16rpx 16rpx; border-radius: 12rpx; box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.06); }
.item-row { display: flex; align-items: center; padding: 20rpx; }
.item-checkbox { transform: scale(0.9); margin-right: 12rpx; }
.item-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: #f2f2f2; margin-right: 16rpx; }
.item-info { flex: 1; display: flex; flex-direction: column; gap: 10rpx; }
.item-title { font-size: 30rpx; color: #111; line-height: 1.4; }
.item-spec { font-size: 24rpx; color: #888; }
.item-price { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; min-width: 120rpx; }
.price { font-size: 30rpx; color: #E53935; font-weight: 700; }
.count { font-size: 24rpx; color: #666; }

/* 底部栏样式，参考购物车页面 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 10px 16px;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
  /* 适配底部安全区 */
  padding-bottom: calc(10px + env(safe-area-inset-bottom));
  padding-bottom: calc(10px + constant(safe-area-inset-bottom));
}

.select-all {
  display: flex;
  align-items: center;
  margin-right: 16px;
}

.select-all checkbox {
  transform: scale(1.2);
  margin-right: 6px;
}

.select-text {
  font-size: 14px;
  color: #333;
}

/* 退款金额组件样式 */
.total-amount-card {
  padding: 0 20rpx 20rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
}

.total-amount-content {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
}

.total-amount-label {
  font-size: 32rpx;
  color: #666;
  margin-right: 8rpx;
}

.total-amount-value {
  font-size: 38rpx;
  font-weight: 600;
  color: #E53935;
}

.submit-btn {
  width: 60px;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #2F8FC7;
  color: #fff;
  border: none;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin-left: auto;
}

/* 数量选择器样式 */
.quantity-selector {
  padding: 0 20rpx 20rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
}

.quantity-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  margin: 12rpx 0;
}

.quantity-btn {
  width: 28px;
  height: 28px;
  line-height: 26px;
  text-align: center;
  font-size: 18px;
  border: 1px solid #e0e0e0;
  border-radius: 4px;
  background-color: #fff;
  color: #333;
}

.quantity-btn.minus {
  border-right: none;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

.quantity-btn.plus {
  border-left: none;
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
}

.quantity-btn.disabled {
  color: #ccc;
  border-color: #e0e0e0;
}

.quantity-input {
  width: 40px;
  height: 28px;
  border: 1px solid #e0e0e0;
  text-align: center;
  font-size: 14px;
}

.item-subtotal {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.subtotal-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}

.subtotal-value {
  font-size: 28rpx;
  color: #E53935;
  font-weight: 600;
}
