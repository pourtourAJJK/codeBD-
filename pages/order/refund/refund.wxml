<view class="refund-page">

  <checkbox-group bindchange="onCheckboxChange">
    <view class="item-card" wx:for="{{items}}" wx:key="id">
      <label class="item-row">
        <checkbox value="{{item.id}}" checked="{{item.selected}}" class="item-checkbox"></checkbox>
        <image class="item-img" src="{{item.cover || '/assets/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="item-info">
          <view class="item-title">{{item.title}}</view>
          <view class="item-spec">规格：{{item.spec}}</view>
        </view>
        <view class="item-price">
          <text class="price">¥{{item.priceYuan}}</text>
          <text class="count">x{{item.quantity}}</text>
        </view>
      </label>
      
      <!-- 数量选择器 -->
      <view class="quantity-selector" wx:if="{{item.selected && item.quantity > 1}}">
        <text class="quantity-label">退款数量：</text>
        <view class="quantity-control">
          <view class="quantity-btn minus {{item.refundQuantity <= 1 ? 'disabled' : ''}}" bindtap="decreaseQuantity" data-index="{{index}}">-</view>
          <input class="quantity-input" type="number" value="{{item.refundQuantity}}" bindinput="onQuantityInput" data-index="{{index}}" />
          <view class="quantity-btn plus {{item.refundQuantity >= item.quantity ? 'disabled' : ''}}" bindtap="increaseQuantity" data-index="{{index}}">+</view>
        </view>
        <view class="item-subtotal">
          <text class="subtotal-label">小计：</text>
          <text class="subtotal-value">¥{{item.subtotal}}</text>
        </view>
      </view>
      
      <!-- 退款金额组件，仅在最后一件商品显示 -->
      <view class="total-amount-card" wx:if="{{index === items.length - 1}}">
        <view class="total-amount-content">
          <text class="total-amount-label">退款金额：</text>
          <text class="total-amount-value">¥{{totalRefundAmount}}</text>
        </view>
      </view>
    </view>
  </checkbox-group>

  <view class="bottom-bar">
    <view class="select-all" bindtap="toggleSelectAll">
      <checkbox checked="{{selectAll}}" class="small-checkbox"></checkbox>
      <text class="select-text">全选</text>
    </view>
    
    <button class="submit-btn" bindtap="submit">提交</button>
  </view>
</view>
