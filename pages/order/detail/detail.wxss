/* 订单详情页面样式 */
.order-detail {
  background-color: #f7f7f7;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 订单状态 */
.order-status {
  background-color: #fff;
  padding: 40rpx 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}
.countdown {
  display: block;
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 10rpx;
  font-weight: normal;
}

.value.countdown {
  color: #ff4d4f;
  font-weight: 500;
}

/* 地址信息 */
.address-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.address-content {
  padding-left: 60rpx;
  position: relative;
}

.address-content::before {
  content: "";
  position: absolute;
  left: 0;
  top: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background-image: url('cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/xiaotubiao/定位.png');
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  z-index: 1;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.name {
  font-size: 32rpx;
  color: #333;
  margin-right: 30rpx;
}

.phone {
  font-size: 32rpx;
  color: #666;
}

.address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 44rpx;
}

/* 商品列表 */
.goods-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.goods-list {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  margin: 10rpx 0;
}

.goods-price-count {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.count {
  font-size: 28rpx;
  color: #666;
}

/* 订单信息 */
.order-info-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.order-info {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
  max-width: 60%;
  text-align: right;
}

/* 价格明细 */
.price-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.price-info {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
}

.discount {
  color: #ff6b6b;
}

.total {
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
  margin-top: 10rpx;
}

.total .label {
  font-size: 32rpx;
  font-weight: bold;
}

.total-value {
  font-size: 36rpx;
  color: #ff6b6b;
  font-weight: bold;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 12rpx 18rpx;
  border-top: 1rpx solid #e5e7eb;
  display: flex;
  justify-content: center;
}

.pill-group {
  display: flex;
  gap: 10rpx;
}

.pill-btn {
  padding: 0 30rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  background-color: #ffffff;
  border: 1rpx solid #E5E7EB;
  border-radius: 24rpx;
  min-width: 150rpx;
  text-align: center;
  height: 70rpx;
  line-height: 70rpx;
}

.pill-btn.modify-address {
  background-color: #2F8FC7;
  border-color: #2F8FC7;
  color: #ffffff;
}

.pill-danger {
  background-color: #1A6DA0;
  border-color: #1A6DA0;
  color: #ffffff;
}

.pill-btn::after {
  border: none;
}



