<!-- 订单列表页面 - 修复样式与功能 -->
<view class="container">
  <!-- 标签切换栏 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{activeTab === 'all' ? 'active' : ''}}" 
      data-tab="all" 
      bindtap="switchTab"
    >
      全部
    </view>
    <view 
      class="tab-item {{activeTab === 'unpaid' ? 'active' : ''}}" 
      data-tab="unpaid" 
      bindtap="switchTab"
    >
      待支付
    </view>
    <view 
      class="tab-item {{activeTab === 'pending_delivery' ? 'active' : ''}}" 
      data-tab="pending_delivery" 
      bindtap="switchTab"
    >
      待配送
    </view>
    <view 
      class="tab-item {{activeTab === 'delivering' ? 'active' : ''}}" 
      data-tab="delivering" 
      bindtap="switchTab"
    >
      配送中
    </view>
    <view 
      class="tab-item {{activeTab === 'completed' ? 'active' : ''}}" 
      data-tab="completed" 
      bindtap="switchTab"
    >
      已完成
    </view>
    <view 
      class="tab-item {{activeTab === 'after_sales' ? 'active' : ''}}" 
      data-tab="after_sales" 
      bindtap="switchTab"
    >
      售后
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{errorMsg && errorMsg !== ''}}" class="error-tip">
    {{errorMsg}}
  </view>

  <!-- 空订单提示 -->
  <view wx:if="{{!loading && orders.length === 0}}" class="empty">
    <view class="empty-icon">📦</view>
    <text class="empty-text">暂无相关订单</text>
    <button class="empty-btn" bindtap="goShopping">去购物</button>
  </view>

  <!-- 订单列表 - 图二风格的订单卡片 -->
  <view wx:else class="order-list">
    <view wx:for="{{orders}}" wx:key="orderId" class="order-card">
      <!-- 店铺信息 -->
      <view class="shop-info">
        <text class="shop-name">硒养山泉</text>
        <view class="order-status" style="color: {{item.statusColor}}">
          {{item.statusText}}
        </view>
      </view>

      <!-- 订单信息 -->
      <view class="order-info">
        <view class="info-row">
          <text class="info-label">取单号</text>
          <text class="info-value">{{item.orderId}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">下单时间</text>
          <text class="info-value">{{item.displayCreateTime}}</text>
        </view>
        <view class="info-row" wx:if="{{item.statusmax === 1 || item.statusmax === '1' && item.countdown}}">
          <text class="info-label">剩余支付时间</text>
          <text class="info-value countdown">{{item.countdown}}</text>
        </view>

      </view>

      <!-- 商品列表 -->
      <view class="product-list">
        <view wx:for="{{item.items}}" wx:for-item="product" wx:key="productId" class="product-item">
          <image 
            class="product-img" 
            src="{{product.cover_image}}" 
            mode="widthFix"
            bindtap="viewProductDetail"
            data-productId="{{product.productId}}"
          ></image>
          <view class="product-info">
            <text class="product-name">{{product.productName}}</text>
            <text class="product-spec">{{product.spec || '默认规格'}}</text>
            <view class="product-price-count">
              <text class="product-price">{{product.displayPrice}}</text>
              <text class="product-count">x{{product.quantity}}</text>
            </view>

          </view>
        </view>
        <view wx:if="{{item.items.length > 1}}" class="product-more">
          共{{item.productCount}}件商品
        </view>
      </view>

      <!-- 金额信息 -->
      <view class="amount-info">
        <view class="amount-row">
          <text class="amount-label">商品金额</text>
          <text class="amount-value">{{item.displayTotalPrice}}</text>
        </view>
        <view class="amount-row">
          <text class="amount-label">配送费</text>
          <text class="amount-value">{{item.displayDeliveryFee}}</text>
        </view>
        <view class="amount-total">
          <text class="total-label">合计</text>
          <text class="total-value">{{item.displayTotalAmount}}</text>
        </view>
      </view>


      <!-- 操作按钮 -->
      <view class="action-buttons">
        <!-- 待支付状态：显示管理、查看详情、去支付 -->
        <block wx:if="{{item.statusmax === 1 || item.statusmax === '1'}}">
          <button 
            class="btn-secondary" 
            bindtap="manageOrder"
            data-order-id="{{item.orderId}}"
          >
            管理
          </button>
          <button 
            class="btn-primary" 
            bindtap="viewOrderDetail"
            data-order-id="{{item.orderId}}"
          >
            查看详情
          </button>
          <button 
            class="btn-primary" 
            bindtap="payOrder"
            data-order-id="{{item.orderId}}"
            data-index="{{index}}"
          >
            去支付
          </button>
        </block>
        
        <!-- 其他状态：只显示管理、查看详情 -->
        <block wx:else>
          <button 
            class="btn-secondary" 
            bindtap="manageOrder"
            data-order-id="{{item.orderId}}"
          >
            管理
          </button>
          <button 
            class="btn-primary" 
            bindtap="viewOrderDetail"
            data-order-id="{{item.orderId}}"
          >
            查看详情
          </button>
        </block>
      </view>
    </view>
    
    <!-- 安全区域占位符 -->
    <view class="safe-area-bottom"></view>
  </view>
</view>