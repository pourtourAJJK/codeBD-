<view class="container">
  <!-- 顶部品牌区（对标鼎湖山泉，统一品牌调性） -->
  <view class="brand-block">
    <image class="brand-logo" src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/logo圆形.png" mode="aspectFit"></image>
    <text class="brand-name">富硒地带</text>
    <text class="brand-slogan">富硒臻选 好物直达家门</text>
  </view>

  <!-- 引导文案区（给用户明确的授权理由，符合送水业务） -->
  <view class="guide-block">
    <text class="guide-title">为保障订单配送与售后联系</text>
    <text class="guide-subtitle">请验证您的常用手机号完成登录</text>
  </view>

  <!-- 隐私协议勾选框：默认未勾选 -->
  <view class="agreement">
    <checkbox-group bindchange="onAgreeChange">
      <checkbox 
        value="agree" 
        checked="{{isAgree}}"
      />
    </checkbox-group>
    <text>我已阅读并同意</text>
    <text class="link" bindtap="openUserAgreement">《用户服务协议》</text>
    <text>和</text>
    <text class="link" bindtap="openPrivacyContract">《隐私政策》</text>
  </view>

  <!-- 核心操作区：手机号快速验证按钮 -->
  <button
    class="phone-auth-btn"
    open-type="getPhoneNumber"
    bindgetphonenumber="getPhoneNumberHandler"
  >
    本机号码快速验证
  </button>

  <!-- 辅助操作区：暂不绑定（弱化处理，可选保留/删除） -->
  <view class="skip-block" bindtap="skipBind">
    <text class="skip-text">暂不绑定，稍后完善</text>
  </view>

  <!-- 隐私协议提示区 -->
  <view class="privacy-tip">
    我们将收集您的手机号用于订单配送与售后联系
  </view>
</view>
