/* pages/login/phone/phone.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
}

/* 品牌区样式 */
.brand-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}
.brand-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.brand-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #2F8FC7; /* 你的品牌主蓝色，和导航栏完全统一 */
  margin-bottom: 10rpx;
}
.brand-slogan {
  font-size: 26rpx;
  color: #666;
}

/* 引导文案区 */
.guide-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.guide-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}
.guide-subtitle {
  font-size: 28rpx;
  color: #666;
}

/* 核心按钮样式（对标鼎湖山泉，蓝色主调+圆角+阴影，精致感拉满） */
.phone-auth-btn {
  width: 82%;
  height: 96rpx;
  line-height: 96rpx;
  background: #2F8FC7;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(47, 143, 199, 0.2);
  margin-bottom: 40rpx;
}
.phone-auth-btn::after {
  border: none; /* 强制去掉微信默认按钮边框 */
}

/* 暂不绑定区（弱化处理，避免干扰核心操作） */
.skip-block {
  padding: 20rpx 0;
}
.skip-text {
  font-size: 28rpx;
  color: #999;
  text-decoration: underline;
}
