/* pages/login/phone/phone.wxss */
.container {
  min-height: 100vh;
  background:#f7f7f7;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 30rpx 60rpx;
  box-sizing: border-box;
  padding-top: calc(120rpx + env(safe-area-inset-top));
  padding-top: calc(120rpx + constant(safe-area-inset-top));
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(60rpx + constant(safe-area-inset-bottom));
}

/* 品牌区样式 */
.brand-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}
.brand-logo {
  width: 180rpx;
  height: 180rpx;
  border-radius:50%;
  margin-bottom: 30rpx;
}
.brand-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.brand-slogan {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 80rpx;
}

/* 引导文案区 */
.guide-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  text-align: center;
  padding: 0 40rpx;
}
.guide-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 52rpx;
}
.guide-subtitle {
  font-size: 30rpx;
  color: #666;
  line-height: 44rpx;
}

/* 核心按钮样式（对标鼎湖山泉，蓝色主调+圆角+阴影，精致感拉满） */
.phone-auth-btn {
  width: 75%;
  height: 100rpx;
  line-height: 100rpx;
  background: #1677ff; /* 自定义颜色，不用微信绿色 */
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(22, 119, 255, 0.2);
  margin-bottom: 60rpx;
}
.phone-auth-btn::after {
  border: none; /* 强制去掉微信默认按钮边框 */
}

/* 隐私协议勾选框样式 */
.agreement {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  width: 100%;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  color: #666;
  padding: 0 40rpx;
}

.agreement checkbox {
  margin-right: 10rpx;
  transform: scale(1.2);
  margin-bottom: 5rpx;
}

.agreement text {
  line-height: 1.5;
  margin-bottom: 5rpx;
}

/* 暂不绑定区（弱化处理，避免干扰核心操作） */
.skip-block {
  padding: 20rpx 0;
  margin-bottom: 60rpx;
}
.skip-text {
  font-size: 28rpx;
  color: #999;
  text-decoration: underline;
}

/* 隐私协议提示区 */
.privacy-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 0 40rpx;
  line-height: 36rpx;
  margin-bottom: 40rpx;
}

.privacy-tip .link {
  color: #07c160;
  text-decoration: underline;
}
