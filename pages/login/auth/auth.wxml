<!--pages/login/auth/auth.wxml-->
<view class="container">
  <view class="header">
    <image class="logo" src="cloud://fuxididai8888-5g9tptvfb7056681.6675-fuxididai8888-5g9tptvfb7056681-1397228946/logo圆形.png" mode="aspectFit"></image>
    <view class="brand-title">富硒地带</view>
    <view class="slogan">富硒臻选 好物直达家门</view>
  </view>

  <view class="bottom-section">
    <!-- 隐私协议勾选框：默认未勾选 -->
    <view class="agreement">
      <checkbox-group bindchange="onAgreeChange">
        <checkbox 
          value="agree" 
          checked="{{isAgree}}"
        />
      </checkbox-group>
      <text>我已阅读并同意</text>
      <text class="link" bindtap="openUserAgreement">《用户服务协议》</text>
      <text>和</text>
      <text class="link" bindtap="openPrivacyContract">《隐私政策》</text>
    </view>

    <!-- 登录按钮：未勾选 → 禁用 -->
    <button 
      class="login-btn" 
      bindtap="handleLogin"
      disabled="{{!isAgree}}"
    >
      账号登录
    </button>

    <!-- 退出按钮 -->
    <button class="exit-btn" bindtap="exitLogin">
      暂不登录，返回首页
    </button>

    <!-- 隐私协议提示，必须包含可点击链接 -->
    <view class="privacy-tip">
      我们将收集您的微信昵称、头像用于账号登录识别
    </view>
  </view>
</view>
