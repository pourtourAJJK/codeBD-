/* pages/login/auth/auth.wxss */
page {
  background-color: #f7f7f7;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  min-height: 100vh;
  padding: 80rpx 50rpx;
  box-sizing: border-box;
  padding-top: calc(80rpx + env(safe-area-inset-top));
  padding-top: calc(80rpx + constant(safe-area-inset-top));
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(80rpx + constant(safe-area-inset-bottom));
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.brand-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-top: 40rpx;
  color: #333;
}

.slogan {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

.bottom-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

/* 核心修正：类名改为login-btn，和WXML完全对应 */
.login-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  border-radius: 45rpx;
  color: #fff;
  background: #1677ff; /* 自定义颜色，不用微信绿色 */
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.2);
  border: none; /* 去掉微信默认按钮边框 */
}

.privacy-tip {
  font-size: 26rpx;
  color: #666;
  margin-top: 30rpx;
  text-align: center;
  line-height: 1.5;
}

.privacy-tip .link {
  color: #07c160;
  text-decoration: underline;
}

/* 退出按钮样式 */
.exit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  border-radius: 45rpx;
  color: #666;
  background-color: #fff;
  font-size: 32rpx;
  margin-top: 30rpx;
  border: 1rpx solid #e0e0e0;
}

/* 修正按钮样式 */
.login-btn::after {
  border: none;
}

.exit-btn::after {
  border: none;
}

/* 隐私协议勾选框样式 */
.agreement {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.agreement checkbox {
  margin-right: 10rpx;
  transform: scale(1.2);
}

.agreement text {
  line-height: 1.5;
}
