<!-- 售后页面 -->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="navbar">
    <view class="navbar-left" bindtap="navigateBack">
      <text class="back-icon">←</text>
    </view>
    <view class="navbar-title">售后</view>
    <view class="navbar-right"></view>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{errorMsg}}" class="error-message">
    {{errorMsg}}
  </view>

  <!-- 标签栏 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{activeTab === 'all' ? 'active' : ''}}" 
      data-tab="all"
      bindtap="switchTab"
    >
      全部
    </view>
    <view 
      class="tab-item {{activeTab === 'refunding' ? 'active' : ''}}" 
      data-tab="refunding"
      bindtap="switchTab"
    >
      退款中
    </view>
    <view 
      class="tab-item {{activeTab === 'refunded' ? 'active' : ''}}" 
      data-tab="refunded"
      bindtap="switchTab"
    >
      退款成功
    </view>
    <view 
      class="tab-item {{activeTab === 'cancelled' ? 'active' : ''}}" 
      data-tab="cancelled"
      bindtap="switchTab"
    >
      已取消
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{orders.length === 0 && !loading}}" class="empty-container">
    <image src="/assets/images/order-refund.svg" class="empty-icon" />
    <text class="empty-text">暂无售后订单</text>
    <button class="empty-button" bindtap="goShopping">去购物</button>
  </view>

  <!-- 订单列表 -->
  <view wx:else class="order-list">
    <view wx:for="{{orders}}" wx:key="orderId" class="order-item">
      <!-- 订单头部 -->
      <view class="order-header">
        <text class="order-time">{{displayCreateTime}}</text>
        <text class="order-status" style="color: {{statusColor}}">{{statusText}}</text>
      </view>

      <!-- 商品列表 -->
      <view class="product-list">
        <view wx:for="{{items}}" wx:key="productId" class="product-item">
          <image src="{{cover_image}}" class="product-image" />
          <view class="product-info">
            <text class="product-name">{{productName}}</text>
            <view class="product-price">
              <text class="price">{{displayPrice}}</text>
              <text class="quantity">x{{quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <view class="order-total">
          <text class="total-label">共{{productCount}}件商品</text>
          <text class="total-price">合计：{{displayTotalAmount}}</text>
        </view>
        <view class="order-actions">
          <button 
            wx:if="{{statusmax === 1 || statusmax === '1'}}" 
            class="action-button primary" 
            bindtap="payOrder"
            data-order-id="{{orderId}}"
          >
            去支付
          </button>
          <button 
            wx:if="{{(statusmax === 1 || statusmax === '1') || (statusmax === 2 || statusmax === '2')}}" 
            class="action-button secondary" 
            bindtap="cancelOrder"
            data-order-id="{{orderId}}"
          >
            取消订单
          </button>
          <button 
            wx:if="{{statusmax === 3 || statusmax === '3'}}" 
            class="action-button secondary" 
            bindtap="remindShip"
            data-order-id="{{orderId}}"
          >
            提醒发货
          </button>
          <button 
            wx:if="{{statusmax === 4 || statusmax === '4'}}" 
            class="action-button primary" 
            bindtap="confirmReceipt"
            data-order-id="{{orderId}}"
          >
            确认收货
          </button>
          <button 
            wx:if="{{statusmax === 5 || statusmax === '5'}}" 
            class="action-button secondary" 
            bindtap="deleteOrder"
            data-order-id="{{orderId}}"
          >
            删除订单
          </button>
          <button 
            class="action-button secondary" 
            bindtap="viewOrderDetail"
            data-order-id="{{orderId}}"
          >
            查看详情
          </button>
        </view>
      </view>
    </view>
  </view>
</view>